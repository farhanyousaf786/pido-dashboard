# Copy to `.env.production` if you need production-specific overrides.
# Keys here override `.env` during `vite build`. Empty VITE_FIREBASE_* values
# will break the live site (blank page).

VITE_API_BASE_URL=https://pido-app.web.app

# Optional: set Firebase vars only if they differ from `.env`:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
