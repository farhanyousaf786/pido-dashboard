# Server
# Must match VITE_API_BASE_URL in the repo root .env.local (e.g. http://localhost:3000)
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# Firebase Admin SDK
# Option A: point to service account json file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Option B: if running on a Google environment you can omit service account
# and rely on application default credentials.

# Default topic for all users
DEFAULT_TOPIC=Pido-all
