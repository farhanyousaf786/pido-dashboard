# Server
# Must match VITE_API_BASE_URL in the repo root .env.local (e.g. http://localhost:3000)
PORT=3000
# Local: http://localhost:5173  |  Production API serving https://pido-app.web.app/ :
# FRONTEND_ORIGIN=https://pido-app.web.app
FRONTEND_ORIGIN=http://localhost:5173

# Firebase Admin SDK
# Option A: point to service account json file (local)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Option B: Heroku / CI — paste the full JSON as one line (heroku config:set FIREBASE_SERVICE_ACCOUNT_JSON='...' )
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Option C: if running on a Google environment you can omit service account
# and rely on application default credentials.

# Default topic for all users
DEFAULT_TOPIC=Pido-all
